# Copy this file to .env and edit values for your environment.
# scripts/run-local.sh and scripts/run-local.ps1 load .env automatically.

# Core runtime settings.
PHLOX_GW_ADDR=127.0.0.1:8080
PHLOX_GW_DATA_DIR=.phlox-gw-data

# Set a stable high-entropy value for shared or production use.
# If omitted, the run helpers generate a local secret file under PHLOX_GW_DATA_DIR.
# PHLOX_GW_SESSION_SECRET=replace-with-a-long-random-secret

# SQLite is the default. Uncomment Postgres settings to use a shared database server.
# PHLOX_GW_DATABASE_DRIVER=sqlite
# PHLOX_GW_DB_PATH=.phlox-gw-data/phlox-gw.db
# PHLOX_GW_DATABASE_URL=postgres://phlox_gw:<password>@localhost:5432/phlox_gw?sslmode=disable

# Provider API keys can be referenced by provider rows in Admin -> Providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# AWS Bedrock uses the standard AWS SDK credential chain.
# AWS_PROFILE=
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional Entra ID / OIDC browser SSO.
# PHLOX_GW_OIDC_ENABLED=false
# PHLOX_GW_OIDC_DISPLAY_NAME="Entra ID"
# PHLOX_GW_OIDC_ISSUER_URL=https://login.microsoftonline.com/<tenant-id>/v2.0
# PHLOX_GW_OIDC_CLIENT_ID=
# PHLOX_GW_OIDC_CLIENT_SECRET=
# PHLOX_GW_OIDC_REDIRECT_URL=http://127.0.0.1:8080/api/auth/oidc/callback
# PHLOX_GW_OIDC_SCOPES="openid profile email"
# PHLOX_GW_OIDC_USERNAME_CLAIM=preferred_username
# PHLOX_GW_OIDC_DEPARTMENT_CLAIM=department
# PHLOX_GW_OIDC_GROUPS_CLAIM=groups
# PHLOX_GW_OIDC_ADMIN_GROUPS=
# PHLOX_GW_OIDC_AUTO_PROVISION=true
